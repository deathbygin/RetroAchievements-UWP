<Page
    x:Class="RetroAchievements_UWP.Profile"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RetroAchievements_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    KeyDown="Page_KeyDown">

    <Grid>
        <Viewbox Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <Grid Width="1120" Height="800">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Profile Information Section with Image (Sticky Header) -->
                <Grid Grid.Row="0" Margin="10,10,20,0">
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" Spacing="20">
                        <!-- User Profile Image -->
                        <Image x:Name="UserProfileImage" Width="84" Height="84" Stretch="UniformToFill"/>

                        <!-- Profile Text Information -->
                        <StackPanel Orientation="Vertical" Spacing="4">
                            <TextBlock Text="User Profile" FontSize="20" FontWeight="Semibold"/>
                            <TextBlock x:Name="UserTextBlock" FontSize="11"/>
                            <TextBlock x:Name="MemberSinceTextBlock" FontSize="11"/>
                            <TextBlock x:Name="MottoTextBlock" FontSize="11"/>
                            <TextBlock x:Name="TotalPointsTextBlock" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- App Title Text -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="AppTitleTextBlock" Text="RetroAchievements" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="v1.0.0" 
                                   FontSize="14" 
                                   Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <!-- Tabs Section (Sticky Headers, Scrollable Content) -->
                <Pivot x:Name="ProfilePivot" Grid.Row="1" Margin="0,20,0,0">
                    <PivotItem Header="Achievements">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Vertical" Padding="20">
                                <TextBlock Text="Recently Unlocked Achievements" FontSize="28" FontWeight="Semibold" Margin="0,0,0,20"/>
                                <GridView x:Name="RecentAchievementsGridView" Height="120"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          IsItemClickEnabled="True"
                                          ItemClick="RecentAchievementsGridView_ItemClick"
                                          ContainerContentChanging="OnContainerContentChanging">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="8"/>
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding ImageUrl}" Width="100" Height="100" Margin="10" Stretch="UniformToFill">
                                                <ToolTipService.ToolTip>
                                                    <ToolTip Padding="6">
                                                        <StackPanel Spacing="3">
                                                             <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18"/>
                                                             <TextBlock Text="{Binding GameTitle}" FontStyle="Italic" FontSize="14"/>
                                                             <TextBlock Text="{Binding Description}" FontSize="14" TextWrapping="Wrap" MaxWidth="300"/>
                                                             <TextBlock Text="{Binding Points}" FontSize="14"/>
                                                             <TextBlock Text="{Binding DateEarnedText}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </ToolTipService.ToolTip>
                                            </Image>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>

                                <TextBlock Text="Recently Played Games" FontSize="28" FontWeight="Semibold" Margin="0,20,0,20"/>
                                <GridView x:Name="RecentGamesGridView" Height="250"
                                          ScrollViewer.HorizontalScrollMode="Disabled"
                                          ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          IsItemClickEnabled="True"
                                          ItemClick="RecentGamesGridView_ItemClick"
                                          ContainerContentChanging="OnContainerContentChanging">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="9"/>
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding ImageUrl}" Width="100" Height="100" Margin="10" Stretch="UniformToFill">
                                                <ToolTipService.ToolTip>
                                                    <ToolTip Padding="6">
                                                        <StackPanel Spacing="3">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18"/>
                                                             <TextBlock Text="{Binding ConsoleName}" FontSize="14" FontStyle="Italic" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                             <TextBlock Text="{Binding AchievementProgress}" FontSize="14"/>
                                                             <ProgressBar Value="{Binding NumAchieved}" Maximum="{Binding NumPossibleAchievements}" Height="6" CornerRadius="2"/>
                                                         </StackPanel>
                                                    </ToolTip>
                                                </ToolTipService.ToolTip>
                                            </Image>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                                <Button x:Name="ViewAllGamesButton" Content="View All Games" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="18" Padding="20,10" Click="ViewAllGames_Click" CornerRadius="4" FontWeight="Semibold"/>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>
                    

                    <PivotItem Header="Want to Play">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Vertical" Padding="20">
                                <TextBlock Text="Want to Play" FontSize="28" FontWeight="Semibold" Margin="0,0,0,20"/>
                                <GridView x:Name="WantToPlayGridView" SelectionMode="None" IsItemClickEnabled="True" ItemClick="WantToPlayGridView_ItemClick"
                                          ContainerContentChanging="OnContainerContentChanging">
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding ImageUrl}" Width="100" Height="100" Margin="10" Stretch="UniformToFill">
                                                <ToolTipService.ToolTip>
                                                    <ToolTip Padding="6">
                                                        <StackPanel Spacing="3">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18"/>
                                                             <TextBlock Text="{Binding ConsoleName}" FontSize="14" FontStyle="Italic" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                            <!-- Want to play list usually just has Title and maybe some console info, but we'll try to show what we can based on GameItem -->
                                                        </StackPanel>
                                                    </ToolTip>
                                                </ToolTipService.ToolTip>
                                            </Image>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <PivotItem Header="Settings">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Vertical" Padding="20">
                                <TextBlock Text="Settings" FontSize="28" FontWeight="Semibold" Margin="0,0,0,20"/>
                                <StackPanel Orientation="Vertical" Spacing="20">
                                    <ToggleSwitch x:Name="HardcoreModeToggle" Header="Display Hardcore Mode Stats" Toggled="HardcoreModeToggle_Toggled"/>
                                    
                                    <ToggleSwitch x:Name="BackgroundThemeToggle" Header="Use Light Background" Toggled="BackgroundThemeToggle_Toggled"/>
                                    
                                    <Button x:Name="ClearCredentialsButton" Content="Clear Saved Credentials" Width="300" Height="50" FontSize="16" Click="ClearCredentials_Click" CornerRadius="4" FontWeight="Semibold" Margin="0,10,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>
                </Pivot>
            </Grid>
        </Viewbox>
    </Grid>
</Page>
